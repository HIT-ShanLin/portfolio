---
import type { SkillsTranslations } from '../i18n/types';

interface Props {
  skills: SkillsTranslations;
}

const { skills } = Astro.props;
---

<section id="skills" class="section">
  <h2 class="section-title">{skills.title}</h2>
  <div class="skills-list">
    {skills.categories.map((category) => (
      <div class="skills-category">
        <h3 class="skills-category-name">{category.name}</h3>
        <dl class="skills-items">
          {category.items.map((item) => (
            <div class="skills-item">
              <dt class="skills-item-name">{item.name}</dt>
              <dd class="skills-item-desc">{item.desc}</dd>
            </div>
          ))}
        </dl>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skills-category {
    padding: 0;
  }

  .skills-category-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-heading);
    margin-bottom: 0.6rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--color-accent);
    font-family: Georgia, 'Times New Roman', serif;
  }

  .skills-items {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .skills-item {
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  .skills-item-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    min-width: 0;
    flex-shrink: 0;
    padding: 0.1rem 0.4rem;
    background: var(--color-tag-bg);
    border-radius: 0.2rem;
    border: 1px solid var(--color-border-light);
  }

  .skills-item-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 768px) {
    .skills-item {
      flex-direction: column;
      gap: 0.2rem;
    }

    .skills-item-name {
      white-space: normal;
    }
  }
</style>
