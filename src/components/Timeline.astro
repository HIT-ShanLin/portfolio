---
import type { TimelineTranslations } from '../i18n/types';

interface Props {
  timeline: TimelineTranslations;
}

const { timeline } = Astro.props;
---

<section id="timeline" class="section">
  <h2 class="section-title">{timeline.title}</h2>
  <div class="timeline">
    {timeline.items.map((item) => (
      <article class="timeline-entry">
        <div class="timeline-meta">
          <span class="timeline-period">{item.period}</span>
          <span class={`timeline-type timeline-type--${item.type}`}>
            {item.type === 'work' ? timeline.workLabel : timeline.internshipLabel}
          </span>
        </div>
        <div class="timeline-body">
          <h3 class="timeline-role">{item.role}</h3>
          <p class="timeline-company">{item.company}</p>
          <p class="timeline-description">{item.description}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .timeline {
    max-width: 100%;
  }

  .timeline-entry {
    display: flex;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .timeline-entry:last-child {
    border-bottom: none;
  }

  .timeline-meta {
    flex-shrink: 0;
    width: 110px;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.1rem;
  }

  .timeline-period {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .timeline-type {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.12rem 0.4rem;
    border-radius: 0.2rem;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    align-self: flex-start;
  }

  .timeline-type--work {
    background: var(--color-accent);
    color: #fff;
  }

  .timeline-type--internship {
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    border: 1px solid var(--color-border);
  }

  .timeline-body {
    flex: 1;
    min-width: 0;
  }

  .timeline-role {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-heading);
    margin-bottom: 0.1rem;
  }

  .timeline-company {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.4rem;
  }

  .timeline-description {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .timeline-entry {
      flex-direction: column;
      gap: 0.3rem;
    }

    .timeline-meta {
      width: 100%;
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
    }
  }
</style>
