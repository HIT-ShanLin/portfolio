---
import type { ProjectsTranslations } from '../i18n/types';
import { fallbackRepos, type RepoInfo } from '../data/fallback-projects';

interface Props {
  projects: ProjectsTranslations;
}

const { projects: t } = Astro.props;

let repos: RepoInfo[] = [];

try {
  const response = await fetch(
    'https://api.github.com/users/HIT-ShanLin/repos?sort=stars&direction=desc&per_page=10'
  );
  if (response.ok) {
    const data: RepoInfo[] = await response.json();
    repos = data
      .filter((r) => !r.fork)
      .slice(0, 6);
  } else {
    repos = fallbackRepos;
  }
} catch {
  repos = fallbackRepos;
}
---

<section id="projects" class="section">
  <h2 class="section-title">{t.title}</h2>

  {repos.length === 0 && (
    <p class="projects-empty">{t.noProjects}</p>
  )}

  <div class="projects-list">
    {repos.map((repo) => (
      <a
        href={repo.html_url}
        target="_blank"
        rel="noopener noreferrer"
        class="project-entry"
      >
        <h3 class="project-name">{repo.name}</h3>
        <p class="project-desc">
          {repo.description || repo.name}
        </p>
        <div class="project-meta">
          {repo.language && (
            <span class="project-lang">{repo.language}</span>
          )}
          <span class="project-stars">⭐ {repo.stargazers_count}</span>
        </div>
      </a>
    ))}
  </div>

  <p class="projects-footer">
    <a
      href="https://github.com/HIT-ShanLin?tab=repositories"
      target="_blank"
      rel="noopener noreferrer"
    >
      {t.viewOnGithub} →
    </a>
  </p>
</section>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .project-entry {
    display: block;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border-light);
    transition: color 0.15s;
  }

  .project-entry:last-of-type {
    border-bottom: none;
  }

  .project-entry:hover .project-name {
    color: var(--color-accent-hover);
  }

  .project-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-link);
    margin-bottom: 0.15rem;
  }

  .project-desc {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.35rem;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .projects-footer {
    padding-top: 0.75rem;
    font-size: 0.85rem;
  }

  .projects-footer a {
    color: var(--color-link);
    font-weight: 500;
  }

  .projects-empty {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
